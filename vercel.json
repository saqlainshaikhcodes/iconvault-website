{
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    { "src": "/icons/(.*)", "dest": "/icons/$1" },
    { "src": "/icons.json", "dest": "/icons.json" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/icons.json",
      "headers": [
        { "key": "Content-Type", "value": "application/json" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/icons/(.*)",
      "headers": [
        { "key": "Content-Type", "value": "image/svg+xml" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}